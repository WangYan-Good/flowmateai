# FlowMate service
HOST=0.0.0.0
PORT=8000

# Microsoft Entra ID / Azure Bot registration
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=

# Alibaba Cloud Model Studio / Qwen official API, Beijing region.
# API keys are region-specific. Change the endpoint if your key belongs to another region.
LLM_PROVIDER=qwen
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=replace-with-your-dashscope-api-key
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1200
LLM_VERIFY_TLS=true
LLM_TRUST_ENV_PROXY=true
ALLOW_DEMO_FALLBACK=false

# Service
HOST=0.0.0.0
PORT=8000

# Microsoft Entra ID / Azure Bot registration
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
# Single-tenant apps: set the Directory (tenant) ID. Leave empty for multi-tenant.
MICROSOFT_APP_TENANT_ID=

# Local OpenAI-compatible GPT-OSS-120B endpoint.
# Both http://host:port and http://host:port/v1 are accepted.
LLM_PROVIDER=company
LLM_BASE_URL=http://host.docker.internal:8001/v1
LLM_API_KEY=
LLM_MODEL=gpt-oss-120b
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1200
# Set false only for an internal endpoint using a self-signed certificate.
LLM_VERIFY_TLS=true
# Keep false for a local/LAN model so inherited HTTP_PROXY does not intercept it.
LLM_TRUST_ENV_PROXY=false

# Disabled by default: a real model failure is returned to Teams.
ALLOW_DEMO_FALLBACK=false
